# Server-only: Nest API origin for next.config.ts rewrites (/api/* → API_ORIGIN/api/*).
# Omit trailing slash. Required for local dev when web and API run on different ports.
API_ORIGIN=http://localhost:3001
# Sentry (set in Vercel for preview/production; optional locally)
# NEXT_PUBLIC_* is baked into the client bundle at build time.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Optional: source map upload during `next build` (CI)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Server (Next.js route handler — app/api/[...path]/route.ts)
# Required in production. Omit trailing slash; path becomes {BACKEND_URL}/api/...
BACKEND_URL=https://your-api-host

# Optional: HTTPS hostnames for next/image remotePatterns (see next.config.ts)
BACKEND_URL=
NEXT_PUBLIC_API_URL=
S3_PUBLIC_URL=
NEXT_PUBLIC_S3_PUBLIC_URL=
NEXT_PUBLIC_S3_PUT_ACL=public-read

# At least one should match the deployed site URL if you rely on absolute links
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_APP_URL=

# Optional: merchant dashboard map (src/sections/merchant/merchant-dashboard.tsx)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
