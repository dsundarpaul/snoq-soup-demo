# Server (Next.js route handler — app/api/[...path]/route.ts)
# Required in production. Omit trailing slash; path becomes {BACKEND_URL}/api/...
BACKEND_URL=https://your-api-host

# Client (baked at build time — redeploy after changes)
# Optional: same-origin /api proxy is used when empty (see src/lib/app-config.ts)
NEXT_PUBLIC_API_URL=

# At least one should match the deployed site URL if you rely on absolute links
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_APP_URL=

# Optional: merchant dashboard map (src/sections/merchant/merchant-dashboard.tsx)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
