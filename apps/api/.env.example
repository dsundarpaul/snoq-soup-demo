# =============================================================================
# SouqSnap API - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=api
API_VERSION=v1

# -----------------------------------------------------------------------------
# Database (MongoDB)
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/souqsnap
# For production with replica set:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/souqsnap?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_REFRESH_REUSE_GRACE_SECONDS=1
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Rate Limiting (Throttler)
# -----------------------------------------------------------------------------
THROTTLER_TTL=60
THROTTLER_LIMIT=100

# -----------------------------------------------------------------------------
# File Storage (MinIO - S3 Compatible)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=souqsnap-uploads
MINIO_REGION=us-east-1
MINIO_PRESIGN_EXPIRATION=300

# S3-compatible settings (alternative naming, used by some services)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=souqsnap-uploads
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

# Max file upload size (bytes)
MAX_FILE_SIZE=5242880

# Allowed MIME types (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/svg+xml

# -----------------------------------------------------------------------------
# Redis (Caching)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SouqSnap
SMTP_FROM_EMAIL=noreply@souqsnap.com
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Twilio (WhatsApp)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# -----------------------------------------------------------------------------
# Magic Token Configuration
# -----------------------------------------------------------------------------
MAGIC_TOKEN_EXPIRY_DAYS=30

# -----------------------------------------------------------------------------
# Scanner Token Configuration
# -----------------------------------------------------------------------------
SCANNER_TOKEN_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# Account Lockout
# -----------------------------------------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=120

# -----------------------------------------------------------------------------
# Voucher Claim Limits
# -----------------------------------------------------------------------------
VOUCHER_CLAIM_LIMIT_PER_DEVICE_HOUR=10

# -----------------------------------------------------------------------------
# Frontend URLs (for CORS and magic links)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
FRONTEND_HUNTER_URL=http://localhost:3000/hunter
FRONTEND_MERCHANT_URL=http://localhost:3000/merchant
FRONTEND_ADMIN_URL=http://localhost:3000/admin

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty

# -----------------------------------------------------------------------------
# Monitoring (Optional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn
# SENTRY_ENVIRONMENT=development
