# =============================================================================
# SouqSnap API - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=api
API_VERSION=v1

# -----------------------------------------------------------------------------
# Database (MongoDB)
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/souqsnap
# For production with replica set:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/souqsnap?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_REFRESH_REUSE_GRACE_SECONDS=1
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Rate Limiting (Throttler)
# -----------------------------------------------------------------------------
THROTTLER_TTL=60
THROTTLER_LIMIT=100

# -----------------------------------------------------------------------------
# File storage (S3-compatible: DigitalOcean Spaces, AWS S3, MinIO, etc.)
# -----------------------------------------------------------------------------
# Env load order: .env, then .env.local (override). Vercel: set these in Project Settings → Environment Variables.
# If S3_HOST is empty but S3_PUBLIC_URL is a DigitalOcean Spaces URL (bucket.region.digitaloceanspaces.com or .cdn.),
# the API host is inferred (e.g. https://myspace.blr1.cdn.digitaloceanspaces.com → blr1.digitaloceanspaces.com).
# S3_HOST: API endpoint hostname only (no scheme, no path). The presigned PUT "url" uses this host.
# DigitalOcean Spaces: e.g. nyc3.digitaloceanspaces.com
# MinIO (local): set explicitly, e.g. localhost or 127.0.0.1 (do not leave empty — empty used to default to localhost and broke presigned URLs)
S3_HOST=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_DEFAULT_BUCKET=souqsnap-uploads
S3_SUB_PATH=uploads
# Public base URL for objects (what you store in the DB; no trailing slash). Often CDN or virtual-hosted style.
# DigitalOcean: e.g. https://<bucket>.nyc3.digitaloceanspaces.com or https://<space-name>.<region>.cdn.digitaloceanspaces.com
# When the hostname starts with the same name as S3_DEFAULT_BUCKET (virtual-hosted), stored URLs are base/<object-key> only.
# MinIO (local): e.g. http://localhost:9000 — stored URLs use base/<bucket>/<key> (path-style).
S3_PUBLIC_URL=
# Region for signing (DO Spaces: use the same region as the endpoint, e.g. nyc3, or the value shown in the Spaces control panel)
S3_REGION=us-east-1

# Max file upload size (bytes)
MAX_FILE_SIZE=5242880

# Allowed MIME types (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/svg+xml

# -----------------------------------------------------------------------------
# Redis (Caching)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SouqSnap
SMTP_FROM_EMAIL=noreply@souqsnap.com
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Twilio (WhatsApp)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# -----------------------------------------------------------------------------
# Magic Token Configuration
# -----------------------------------------------------------------------------
MAGIC_TOKEN_EXPIRY_DAYS=30

# -----------------------------------------------------------------------------
# Scanner Token Configuration
# -----------------------------------------------------------------------------
SCANNER_TOKEN_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# Account Lockout
# -----------------------------------------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=120

# -----------------------------------------------------------------------------
# Voucher Claim Limits
# -----------------------------------------------------------------------------
VOUCHER_CLAIM_LIMIT_PER_DEVICE_HOUR=10

# -----------------------------------------------------------------------------
# Frontend URLs (for CORS and magic links)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
FRONTEND_HUNTER_URL=http://localhost:3000/hunter
FRONTEND_MERCHANT_URL=http://localhost:3000/merchant
FRONTEND_ADMIN_URL=http://localhost:3000/admin

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (read by app as CORS_ORIGIN)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty

# -----------------------------------------------------------------------------
# Monitoring (Optional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn
# SENTRY_ENVIRONMENT=development
