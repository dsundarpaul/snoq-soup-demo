# Test Environment Variables
NODE_ENV=test

# JWT Configuration
JWT_SECRET=test-jwt-secret-for-e2e-testing
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Database (MongoMemoryServer will be used)
MONGODB_URI=mongodb://localhost:27017/souqsnap_test

# Redis (mocked in tests)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Admin credentials for testing
ADMIN_EMAIL=admin@souqsnap.com
ADMIN_PASSWORD=AdminPass123!

# Email (mocked in tests)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@souqsnap.com
SMTP_PASS=testpassword
EMAIL_USER=test@souqsnap.com
EMAIL_PASS=testpassword

# Twilio (mocked in tests)
TWILIO_SID=test-sid
TWILIO_TOKEN=test-token
TWILIO_PHONE=+1234567890
TWILIO_ACCOUNT_SID=test-sid
TWILIO_AUTH_TOKEN=test-token

# AWS S3 (mocked in tests)
AWS_ACCESS_KEY_ID=test-key
AWS_SECRET_ACCESS_KEY=test-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=test-bucket

# MinIO/S3 Storage (mocked in tests)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=test-minio-key
MINIO_SECRET_KEY=test-minio-secret
MINIO_BUCKET=souqsnap-uploads
MINIO_USE_SSL=false
MINIO_PORT=9000
