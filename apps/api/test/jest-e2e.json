{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^@souqsnap/shared$": "<rootDir>/../../packages/shared/src",
    "^@souqsnap/shared/(.*)$": "<rootDir>/../../packages/shared/src/$1"
  },
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"]
}
